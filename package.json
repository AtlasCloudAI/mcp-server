{
  "name": "atlascloud-mcp",
  "version": "1.4.0",
  "description": "MCP server for AI image / video / 3D / audio (TTS) generation & LLM chat. Use Sora 2, Veo 3, Kling 3, Seedance 2, Flux 2, Nano Banana Pro, Hunyuan 3D, Seed Audio in Claude Code, Cursor, Codex, Gemini CLI.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "atlascloud-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "atlascloud",
    "atlas-cloud",
    "claude-code",
    "codex",
    "gemini-cli",
    "cursor",
    "cline",
    "sora-2",
    "veo-3",
    "kling-3",
    "seedance-2",
    "flux-2",
    "nano-banana",
    "gpt-image-2",
    "ai-video-generation",
    "text-to-image",
    "text-to-speech",
    "tts",
    "seed-audio",
    "hunyuan-3d",
    "image-to-3d",
    "llm",
    "image-generation",
    "video-generation",
    "audio-generation",
    "3d-generation"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "undici": "^7.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
